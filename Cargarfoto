<body>

<div class="container">

  <img src="LogoSinSlogan.png" class="logo">
  <h1>My V-Care</h1>

  <input type="file" id="imagen" accept="image/*">

  <button class="btn" id="btnSubir">Agregar foto 📷</button>

  <div class="progress" id="progress">
    <div class="progress-bar" id="progressBar"></div>
  </div>

  <p id="estado"></p>
  <img id="preview">

</div>

<script>
const API_KEY = "7c5016836a04a9f4ff6d6bad4d64f851";

const boton = document.getElementById("btnSubir");
const input = document.getElementById("imagen");
const estado = document.getElementById("estado");
const preview = document.getElementById("preview");
const progress = document.getElementById("progress");
const progressBar = document.getElementById("progressBar");

boton.addEventListener("click", () => {
  input.click();
});

input.addEventListener("change", () => {
  const file = input.files[0];
  if (!file) return;

  const reader = new FileReader();

  reader.onload = function () {
    const base64 = reader.result.split(',')[1];

    estado.innerText = "Subiendo imagen...";
    progress.style.display = "block";
    progressBar.style.width = "30%";

    fetch("https://api.imgbb.com/1/upload?key=" + API_KEY, {
      method: "POST",
      body: new URLSearchParams({
        image: base64
      })
    })
    .then(res => {
      progressBar.style.width = "70%";
      return res.json();
    })
    .then(data => {
      const url = data.data.url;

      progressBar.style.width = "100%";

      estado.innerText = "Imagen subida correctamente ✔";
      preview.src = url;
      preview.style.display = "block";

      console.log("URL:", url);

      setTimeout(() => {
        progress.style.display = "none";
        progressBar.style.width = "0%";
      }, 1000);
    })
    .catch(err => {
      estado.innerText = "Error al subir ❌";
      console.error(err);
    });
  };

  reader.readAsDataURL(file);
});
</script>

</body>
</html>
